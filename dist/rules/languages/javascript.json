{
  "id": "javascript",
  "aliases": ["js", "node", "nodejs"],
  "extensions": [".js", ".cjs", ".mjs", ".jsx"],

  "dynamic_exec_sinks": [
    "eval",
    "Function",
    "GeneratorFunction",
    "AsyncFunction",
    "Function.prototype.constructor",
    "globalThis.eval",
    "window.eval",
    "self.eval",
    "vm.runInThisContext",
    "vm.runInNewContext",
    "vm.runInContext",
    "vm.compileFunction",
    "vm.Script",
    "setTimeout",
    "setInterval",
    "setImmediate",
    "execScript",
    "WebAssembly.compile",
    "WebAssembly.instantiate"
  ],

  "decoders": [
    "atob",
    "Buffer.from",
    "Buffer.allocUnsafe",
    "Buffer.alloc",
    "TextDecoder.prototype.decode",
    "decodeURIComponent",
    "decodeURI",
    "unescape",
    "zlib.gunzipSync",
    "zlib.gunzip",
    "zlib.inflateSync",
    "zlib.inflate",
    "zlib.brotliDecompressSync",
    "zlib.brotliDecompress",
    "zlib.unzipSync",
    "crypto.createDecipheriv",
    "crypto.createDecipher",
    "crypto.privateDecrypt",
    "crypto.publicDecrypt",
    "crypto.subtle.decrypt",
    "lzma.decompress"
  ],

  "deserializers": [
    "JSON.parse",
    "v8.deserialize",
    "node:v8.deserialize"
  ],

  "network_io": [
    "fetch",
    "XMLHttpRequest",
    "http.get",
    "http.request",
    "https.get",
    "https.request",
    "net.connect",
    "net.createConnection",
    "tls.connect",
    "dgram.createSocket",
    "axios",
    "axios.get",
    "axios.post",
    "axios.request",
    "got",
    "node-fetch",
    "request",
    "undici.fetch",
    "undici.request",
    "WebSocket"
  ],

  "secrets_io": [
    "process.env",
    "process.platform",
    "os.userInfo",
    "os.homedir",
    "fs.readFileSync",
    "fs.readFile",
    "fs.promises.readFile"
  ],

  "shell_exec": [
    "child_process.exec",
    "child_process.execSync",
    "child_process.execFile",
    "child_process.execFileSync",
    "child_process.spawn",
    "child_process.spawnSync",
    "child_process.fork"
  ],

  "library_load": [
    "process.dlopen",
    "require",
    "import",
    "module.require"
  ],

  "obfuscator_id_patterns": [
    "^_0x[a-f0-9]{4,}$",
    "^[Oo0]{3,}$",
    "^[Il1]{3,}$"
  ],
  "min_mean_identifier_length": 2.0,
  "obfuscator_id_min_ratio": 0.2,

  "string_concat_operators": ["+", "+=", "`"],

  "language_specific_detectors": [
    "javascript.string-array-decoder",
    "javascript.require-from-network"
  ],

  "manifests": ["package-json", "package-lock-json", "yarn-lock", "pnpm-lock", "npmrc"],

  "notes": "Layer A (entropy/bidi/line length) catches most obfuscator output; the string-array-decoder language detector handles javascript-obfuscator's canonical output (axios 2026 incident)."
}

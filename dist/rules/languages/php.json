{
  "id": "php",
  "aliases": [],
  "extensions": [".php", ".php3", ".php4", ".php5", ".phtml", ".phar"],

  "dynamic_exec_sinks": [
    "eval",
    "assert",
    "create_function",
    "call_user_func",
    "call_user_func_array",
    "ReflectionFunction",
    "ReflectionMethod.invoke",
    "ReflectionMethod.invokeArgs",
    "preg_replace_callback",
    "preg_replace"
  ],

  "decoders": [
    "base64_decode",
    "hex2bin",
    "pack",
    "convert_uudecode",
    "gzinflate",
    "gzuncompress",
    "gzdecode",
    "bzdecompress",
    "openssl_decrypt",
    "mcrypt_decrypt",
    "mcrypt_module_open",
    "rawurldecode",
    "urldecode",
    "html_entity_decode",
    "str_rot13",
    "strrev",
    "convert_cyr_string"
  ],

  "deserializers": [
    "unserialize",
    "json_decode"
  ],

  "network_io": [
    "file_get_contents",
    "fopen",
    "curl_init",
    "curl_exec",
    "fsockopen",
    "pfsockopen",
    "stream_socket_client",
    "Guzzle\\Http\\Client.send",
    "GuzzleHttp\\Client.request"
  ],

  "secrets_io": [
    "$_ENV",
    "$_SERVER",
    "getenv",
    "apache_getenv",
    "phpinfo"
  ],

  "shell_exec": [
    "system",
    "shell_exec",
    "exec",
    "passthru",
    "popen",
    "proc_open",
    "pcntl_exec"
  ],

  "library_load": [
    "dl",
    "include",
    "include_once",
    "require",
    "require_once"
  ],

  "obfuscator_id_patterns": [
    "^\\$_+[0-9]+$",
    "^\\$[Il1O0]{3,}$"
  ],
  "min_mean_identifier_length": 2.0,
  "obfuscator_id_min_ratio": 0.25,

  "string_concat_operators": [".", ".="],

  "language_specific_detectors": [
    "php.assert-string-eval",
    "php.preg-replace-e-modifier",
    "php.variable-variable-call",
    "php.create-function-deprecated",
    "php.include-from-network"
  ],

  "manifests": ["composer-json", "composer-lock"],

  "notes": "PHP webshells are the most common form of PHP malware. assert($string) historically evaluated its argument; preg_replace with the /e modifier is deprecated but still seen in old shells. Variable variables ${$x}() let an attacker call any function whose name is computed at runtime."
}
